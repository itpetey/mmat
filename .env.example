# Postgres connection string for the event store, memory store, and artefact store.
# When set, stores use Postgres.  When unset, the coordinator and library
# crates fall back to SQLite databases (events.db, memory.db) and file-based
# artefact storage (.mmat/artefacts/).
# NOTE: the mmat-workbench binary requires DATABASE_URL and will fail at
# startup if it is not set.
DATABASE_URL=postgres://mmat:mmat@localhost:5432/mmat
