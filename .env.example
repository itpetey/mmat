# Postgres connection string for the event store, memory store, and artefact store.
# When set, the application uses Postgres instead of SQLite for all storage.
# When unset, the application falls back to SQLite databases (events.db, memory.db)
# and file-based artefact storage (.mmat/artefacts/).
DATABASE_URL=postgres://mmat:mmat@localhost:5432/mmat
