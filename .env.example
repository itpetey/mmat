# Copy this file to .env before running docker compose if you need to override defaults.

# Host repository MMAT should inspect and edit. Docker Compose bind-mounts this at
# MMAT_PROJECT_PATH inside the containers.
MMAT_HOST_PROJECT_ROOT=.
MMAT_PROJECT_PATH=/workspace/project

# Browser port for the MMAT web UI.
MMAT_PORT=8080
MMAT_DEV_PORT=8080

# Builder LLM (builder / builder-prod services) - defaults to LM Studio on the host.
MMAT_BUILDER_LLM_BASE_URL=http://host.docker.internal:1234/v1
MMAT_BUILDER_LLM_API_KEY=

# Frontend LLM (frontend / frontend-prod services) - defaults to OpenAI.
MMAT_FRONTEND_LLM_BASE_URL=https://api.openai.com/v1
MMAT_FRONTEND_LLM_API_KEY=

# Embeddings. If MMAT_EMBEDDING_API_KEY is blank, MMAT falls back to OPENAI_API_KEY.
OPENAI_API_KEY=
MMAT_EMBEDDING_API_KEY=
MMAT_EMBEDDING_BASE_URL=https://api.openai.com/v1
MMAT_EMBEDDING_MODEL=text-embedding-3-small
MMAT_EMBEDDING_DIMENSION=1536

# Qdrant is provided by docker-compose.yml; override only for an external instance.
QDRANT_PORT=6333
MMAT_QDRANT_API_KEY=

MMAT_DATA_PATH=/data/mmat
MMAT_KNOWLEDGE_REPO=mmat
